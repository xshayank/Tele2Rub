# .env.kharej.example — Environment variables for the Kharej VPS worker.
#
# Copy this file to .env.kharej and fill in real values before running.
# NEVER commit .env.kharej to version control.
#
# Usage:
#   cp .env.kharej.example .env.kharej
#   export $(grep -v '^#' .env.kharej | xargs)
#   python -m kharej.worker
#
# See docs/how-to-run-locally.md for full setup instructions.

# ── Rubika control channel (REQUIRED) ────────────────────────────────────────
# The Rubika session name for the Kharej-side account.
# Obtained by running rubpy's session saver on the Kharej Rubika account.
# See: https://github.com/shayanheidari01/rubpy
# WARNING: treat this value as a secret — it grants full account access.
RUBIKA_SESSION_KHAREJ=<kharej-rubpy-session-name>

# The Rubika object GUID of the Iran-side account.
# All inbound messages not originating from this GUID are silently rejected.
# Obtain from the Iran-side Rubika client after its session is initialised.
IRAN_RUBIKA_ACCOUNT_GUID=<iran-rubika-guid>

# ── Arvan S2 Object Storage (REQUIRED) ───────────────────────────────────────
# Kharej needs write credentials; Iran uses separate read-only credentials.
ARVAN_S2_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_S2_ACCESS_KEY_WRITE=<write-access-key>
ARVAN_S2_SECRET_WRITE=<write-secret-key>
ARVAN_S2_BUCKET=rubetunes-media

# Arvan S2 region — must match the bucket's region.
# Default: ir-thr-at1  (Arvan Tehran datacenter)
# Source: kharej/s2_client.py
ARVAN_S2_REGION=ir-thr-at1

# ── Runtime tuning (KHAREJ_* prefix) ─────────────────────────────────────────
# Any KHAREJ_<KEY> env var is loaded into KharejSettings with the prefix
# stripped and the key lower-cased (e.g. KHAREJ_DOWNLOAD_DIR → "download_dir").
# Disk-persisted values in kharej/state/kharej_settings.json override these.
# Source: kharej/settings.py

# How often (seconds) progress events are throttled before being sent to Iran.
# Default: 3
KHAREJ_PROGRESS_THROTTLE_SECONDS=3

# Base directory for in-progress download files.
# Default: /tmp/kharej_downloads
KHAREJ_DOWNLOAD_DIR=/tmp/kharej_downloads

# Default yt-dlp audio format selector for YouTube/SoundCloud/Bandcamp/Amazon.
# Default: bestaudio/best
# Source: kharej/downloaders/youtube.py
KHAREJ_DEFAULT_AUDIO_QUALITY=bestaudio/best

# Path to yt-dlp binary.  Defaults to "yt-dlp" (searched in $PATH).
# Source: kharej/downloaders/bandcamp.py, amazon.py, soundcloud.py
KHAREJ_YTDLP_BIN=yt-dlp

# Path to a cookies.txt (Netscape format) used by yt-dlp for age-restricted
# or sign-in-required content.  Leave unset to run without cookies.
# Source: kharej/downloaders/youtube.py
#KHAREJ_COOKIES_PATH=/path/to/cookies.txt

# Maximum parallel per-track downloads inside a batch job.  Default: 2
# Source: kharej/downloaders/batch.py
KHAREJ_DOWNLOAD_CONCURRENCY=2

# Set to "true" to split large ZIP archives into parts before uploading.
# Default: false
# Source: kharej/downloaders/batch.py
KHAREJ_ENABLE_ZIP_SPLIT=false

# ZIP part size threshold (MB).  Only used when KHAREJ_ENABLE_ZIP_SPLIT=true.
# Default: 200
# Source: kharej/downloaders/batch.py
KHAREJ_ZIP_SPLIT_THRESHOLD_MB=200

# ── Logging (shared with rubetunes) ──────────────────────────────────────────
# LOG_FORMAT=text emits human-readable lines; LOG_FORMAT=json emits one JSON
# object per line (suitable for log aggregators).
# Default: text
# Source: rubetunes/logging_setup.py
LOG_FORMAT=text

# ── Prometheus metrics (shared with rubetunes) ────────────────────────────────
# Expose /metrics on this port.  Set to 0 to disable the metrics server.
# Default: 9090
# Source: rubetunes/metrics.py
METRICS_PORT=9090

# ── Sentry error reporting (shared with rubetunes) ───────────────────────────
# Set to your Sentry DSN to enable error reporting.  Leave blank to disable.
# Source: rubetunes/sentry_setup.py
SENTRY_DSN=

# ── Graceful shutdown ─────────────────────────────────────────────────────────
# SHUTDOWN_TIMEOUT_SEC is read by the legacy main.py bot (not by the new
# Kharej worker).  The kharej.worker uses a hard-coded 60-second drain in
# dispatcher.shutdown().  Listed here for completeness when running main.py.
# Source: main.py
#SHUTDOWN_TIMEOUT_SEC=30

# ── Per-user rate limiting (shared with rubetunes) ───────────────────────────
# Maximum number of tracks a user can request per rolling hour.
# Default: 100
# Source: rubetunes/rate_limiter.py
USER_TRACKS_PER_HOUR=100

# ── Disk space guard (shared with rubetunes) ──────────────────────────────────
# Estimated MB per FLAC track (used to forecast disk usage before batch jobs).
# Default: 30
# Source: rubetunes/disk_guard.py
HEURISTIC_MB_PER_TRACK=30

# Reject a batch when free_mb < MIN_FREE_SPACE_MULTIPLIER × estimated_mb.
# Default: 2.0
# Source: rubetunes/disk_guard.py
MIN_FREE_SPACE_MULTIPLIER=2.0

# Absolute minimum free space (MB) regardless of track-count estimate.
# Default: 500
# Source: rubetunes/disk_guard.py
MIN_FREE_SPACE_MB=500

# ── Provider credentials (optional) ──────────────────────────────────────────
# Leave any provider blank if you do not use it; the worker will skip that
# source and fall back to the next available provider.

# Tidal OAuth client token for metadata resolution and ISRC lookup.
# Tracks are downloaded via the ISRC waterfall (Qobuz/Tidal-Alt/Deezer/YouTube).
# Source: rubetunes/providers/tidal.py
TIDAL_TOKEN=

# Comma-separated list of Tidal Alt proxy base URLs.
# Defaults to the built-in public proxies when left blank.
# Source: rubetunes/providers/tidal_alt.py
TIDAL_ALT_BASES=

# musicdl provider settings (NetEase, QQ Music, …)
# Source: rubetunes/providers/musicdl/config.py
MUSICDL_DOWNLOAD_DIR=
MUSICDL_DEFAULT_SOURCES=
MUSICDL_PROXY=
MUSICDL_MAX_RETRIES=1
MUSICDL_CONNECT_TIMEOUT=5
MUSICDL_READ_TIMEOUT=15

# Spotify OAuth app credentials (optional — anonymous token is obtained
# automatically via TOTP; only needed as a fallback).
# Source: rubetunes/spotify/session.py
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Deezer ARL cookie — enables lossless FLAC downloads.
# Obtain from your browser's cookies after logging in to deezer.com.
# Source: rubetunes/downloader.py
DEEZER_ARL=

# Qobuz credentials — auto-scraped and cached locally.
# Usually not required unless auto-scraping fails.
# Source: rubetunes/downloader.py, rubetunes/providers/qobuz.py
QOBUZ_EMAIL=
QOBUZ_PASSWORD=

# ── Circuit breaker (shared with rubetunes) ───────────────────────────────────
# Open the provider circuit after CIRCUIT_FAIL_THRESHOLD consecutive failures
# within CIRCUIT_FAIL_WINDOW_SEC seconds; keep it open for CIRCUIT_OPEN_DURATION_SEC.
# Source: rubetunes/circuit_breaker.py
CIRCUIT_FAIL_THRESHOLD=3
CIRCUIT_FAIL_WINDOW_SEC=300
CIRCUIT_OPEN_DURATION_SEC=600
