# iran/.env.example — Environment variables for the Iran VPS service (Track B).
#
# Copy this file to iran/.env and fill in real values before deploying.
# NEVER commit iran/.env to version control.
#
# Usage:
#   cp iran/.env.example iran/.env

# ── Application ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
IRAN_SECRET_KEY=change-me-in-production
IRAN_ENVIRONMENT=production
IRAN_ENABLE_API_DOCS=0
IRAN_DATABASE_URL=postgresql+asyncpg://iran:password@db:5432/rubetunes_iran

# ── Postgres (used by docker-compose) ────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production

# ── Rubika (Iran-side session) ────────────────────────────────────────────────
# Obtain from running rubpy's session saver on the Iran-side Rubika account.
IRAN_RUBIKA_SESSION_IRAN=<base64-encoded rubpy session>
IRAN_KHAREJ_RUBIKA_ACCOUNT_GUID=<kharej-rubika-guid>
IRAN_IRAN_RUBIKA_ACCOUNT_GUID=<iran-rubika-guid>

# ── Arvan S2 (read-only credentials — Iran VPS only) ─────────────────────────
# NEVER use the Kharej write credentials here.
IRAN_S2_ENDPOINT_URL=https://s3.ir-thr-at1.arvanstorage.ir
IRAN_S2_ACCESS_KEY=<read-access-key>
IRAN_S2_SECRET_KEY=<read-secret-key>
IRAN_S2_BUCKET=rubetunes-media

# ── Feature toggles ───────────────────────────────────────────────────────────
IRAN_S2_PRESIGN_EXPIRE_SECONDS=3600
IRAN_MAX_JOBS_PER_HOUR=10

# ── Logging / monitoring ──────────────────────────────────────────────────────
IRAN_LOG_LEVEL=INFO
IRAN_LOG_FORMAT=json
